# --- Upstream svix-server ---------------------------------------------------
# URL of the self-hosted svix-server. Inside docker-compose this is the service
# name + port; locally it is http://localhost:8071.
SVIX_SERVER_URL=http://localhost:8071

# Privileged org/admin JWT. Generate with:
#   docker compose exec svix-server svix-server jwt generate
# This token can read every tenant — it stays server-side and never reaches the
# browser.
SVIX_ADMIN_TOKEN=

# --- svix-ui session --------------------------------------------------------
# Secret used to sign operator session cookies. Use a long random string, e.g.
#   openssl rand -hex 32
SVIX_UI_SESSION_SECRET=

# Operator (admin) login credentials for the console.
SVIX_UI_OPERATOR_USERNAME=admin
SVIX_UI_OPERATOR_PASSWORD=change-me

# Public origin of svix-ui, used to build consumer App Portal magic links.
# Optional; falls back to the incoming request origin.
SVIX_UI_PUBLIC_URL=http://localhost:3000
